generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Ensemble {
  id          String   @id @default(uuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  conductorId String
  
  scores      Score[]
  rehearsals  Rehearsal[]
  members     Member[]
}

model Member {
  id         String   @id @default(uuid())
  name       String
  role       String   // CONDUCTOR or PLAYER
  instrument String?
  section    String?  // 声部，如 "violin", "cello", "flute"
  ensembleId String
  ensemble   Ensemble @relation(fields: [ensembleId], references: [id], onDelete: Cascade)
  
  marks      Mark[]
  createdAt  DateTime @default(now())
}

model Score {
  id           String   @id @default(uuid())
  title        String
  composer     String?
  fileUrl      String   // PDF 或 MusicXML 文件路径
  fileType     String   // "pdf" | "musicxml"
  audioUrl     String?  // 参考音频
  ensembleId   String
  ensemble     Ensemble @relation(fields: [ensembleId], references: [id], onDelete: Cascade)
  
  measures     Measure[]
  marks        Mark[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Measure {
  id        String @id @default(uuid())
  number    Int    // 小节号
  scoreId   String
  score     Score  @relation(fields: [scoreId], references: [id], onDelete: Cascade)
  
  startTime Float? // 音频中的起始时间（秒）
  endTime   Float? // 音频中的结束时间（秒）
  
  cues      Cue[]
}

model Mark {
  id          String   @id @default(uuid())
  type        String   // DRAWING, TEXT, HIGHLIGHT
  data        String   // JSON 序列化的标记数据
  x           Float
  y           Float
  width       Float?
  height      Float?
  page        Int      // 乐谱页码
  measureId   String?
  scoreId     String
  score       Score    @relation(fields: [scoreId], references: [id], onDelete: Cascade)
  creatorId   String
  creator     Member   @relation(fields: [creatorId], references: [id])
  targetSection String? // 目标声部，null表示全体
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Cue {
  id          String   @id @default(uuid())
  type        String   // CLICK, COUNT_IN, METRONOME, DEMO_AUDIO
  measureId   String
  measure     Measure  @relation(fields: [measureId], references: [id], onDelete: Cascade)
  targetSection String?  // 目标声部
  audioUrl    String?  // 提示音音频
  bpm         Int?     // 节拍器速度
  timeSignature String? // 拍号
  createdAt   DateTime @default(now())
}

model Rehearsal {
  id          String   @id @default(uuid())
  ensembleId  String
  ensemble    Ensemble @relation(fields: [ensembleId], references: [id], onDelete: Cascade)
  scoreId     String?
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  recordingUrl String? // 排练录音文件
  
  events      RehearsalEvent[]
}

model RehearsalEvent {
  id          String   @id @default(uuid())
  rehearsalId String
  rehearsal   Rehearsal @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)
  type        String   // MARK_ADDED, CUE_SENT, SECTION_PLAYING, MISTAKE_DETECTED
  data        String   // JSON 事件数据
  timestamp   DateTime @default(now())
}

// Enums removed - using String types for SQLite compatibility
